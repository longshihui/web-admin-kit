{
  "name": "@colorless/hooks",
  "version": "1.0.1",
  "description": "面向中后台项目的 Vue 组合式函数包，提供分页、滚动加载、筛选快照和可等待弹层等能力。",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "composables",
    "hooks",
    "admin"
  ],
  "homepage": "https://longshihui.github.io/web-admin-kit/packages/hooks/",
  "bugs": {
    "url": "https://github.com/longshihui/web-admin-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/longshihui/web-admin-kit.git",
    "directory": "packages/hooks"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21"
  },
  "peerDependencies": {
    "vue": "^3.4.35"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "vite-plugin-dts": "^5.0.2",
    "vite": "^8.0.16",
    "vitest": "^2.1.9",
    "vue": "^3.4.35"
  }
}

{
  "name": "@colorless/permission-kit",
  "version": "1.0.0",
  "description": "面向中后台项目的权限能力包，提供权限 SDK、组合式消费、模板切面、指令和路由守卫。",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue-router",
    "permission",
    "access-control",
    "admin"
  ],
  "homepage": "https://longshihui.github.io/web-admin-kit/packages/permission-kit/",
  "bugs": {
    "url": "https://github.com/longshihui/web-admin-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/longshihui/web-admin-kit.git",
    "directory": "packages/permission-kit"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.4.18",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/language-core": "^3.1.8",
    "vite-plugin-dts": "^5.0.2",
    "vite": "^8.0.16",
    "vitest": "^2.1.9",
    "vue": "^3.4.18",
    "vue-router": "^4.2.5"
  }
}

{
  "name": "@colorless/shared",
  "version": "1.0.0",
  "description": "面向中后台项目的共享基础能力包，提供通用类型、常量、正则表达式和轻量校验工具。",
  "license": "MIT",
  "keywords": [
    "typescript",
    "utilities",
    "validators",
    "constants",
    "admin"
  ],
  "homepage": "https://longshihui.github.io/web-admin-kit/packages/shared/",
  "bugs": {
    "url": "https://github.com/longshihui/web-admin-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/longshihui/web-admin-kit.git",
    "directory": "packages/shared"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "js-base64": "^3.7.7",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "vite-plugin-dts": "^5.0.2",
    "vite": "^8.0.16",
    "vitest": "^2.1.9"
  }
}

{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "requireCleanWorkingDir": true,
    "requireUpstream": false,
    "commit": true,
    "commitMessage": "chore(release): v${version}",
    "tag": true,
    "tagName": "v${version}",
    "tagAnnotation": "v${version}",
    "push": true
  },
  "github": {
    "release": true,
    "releaseName": "${tagName}",
    "releaseNotes": "cat .git/.release-notes.md"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": [
      "pnpm release:notes",
      "pnpm check:push",
      "pnpm build",
      "pnpm docs:build"
    ],
    "before:git:release": "pnpm release:version"
  }
}

{
  "name": "web-admin-kit",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "check": "pnpm typecheck && pnpm lint",
    "check:push": "pnpm typecheck && pnpm lint && pnpm test:run",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "commit": "cz",
    "docs:dev": "vitepress dev .",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "commitlint:from": "commitlint",
    "prepare": "husky",
    "publish:ci": "changeset publish",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": "eslint --max-warnings=0",
    "*.{ts,mts,cts}": "tsc-files --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "commitizen": "^4.3.2",
    "cz-git": "^1.13.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^17.0.7",
    "tsc-files": "^1.1.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.61.0",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.9"
  }
}

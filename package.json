{
  "name": "web-admin-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "commit": "cz",
    "docs:dev": "vitepress dev .",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "commitlint": "commitlint --edit",
    "commitlint:from": "commitlint",
    "prepare": "husky",
    "release": "release-it",
    "release:dry": "release-it --dry-run --no-git.requireCleanWorkingDir",
    "release:ci": "release-it --ci",
    "release:changelog": "release-it --dry-run --changelog --no-git.requireCleanWorkingDir",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^25.9.3",
    "commitizen": "^4.3.2",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cz-git": "^1.13.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "release-it": "^20.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.61.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  }
}
